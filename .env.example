# Environment variables example
PORT=3000
NODE_ENV=development

# Supabase API Configuration (HTTP Client)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key

# Supabase Direct PostgreSQL Connection (recommended for migrations and direct SQL)
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres
